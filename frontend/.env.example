# Local development (SQLite file in /data)
LIBSQL_URL=file:./data/restaurant.db

# Production on Vercel (REQUIRED) — https://turso.tech
LIBSQL_URL=libsql://your-database.turso.io
LIBSQL_AUTH_TOKEN=your-turso-token

JWT_SECRET=change-this-to-a-long-random-secret
SETUP_SECRET=same-or-different-secret-for-one-time-seed
ADMIN_EMAIL=admin@restaurant.com
ADMIN_PASSWORD=admin123
